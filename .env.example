# Supabase (required)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Production site URL — set to your Cloudflare custom domain
# e.g. https://tasks.elixir.com
NEXT_PUBLIC_APP_URL=https://tasks.elixir.com

NEXT_PUBLIC_TIMEZONE=America/New_York

# Cloudflare Workers (set in dashboard / wrangler secret)
# No additional keys required for basic deploy via OpenNext
